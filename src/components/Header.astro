---
import { SITE_NAME } from "../consts";
import ToggleTheme from "./ToggleTheme.astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
---

<div
  class="container mx-auto md:max-w-4xl p-4 fixed top-0 left-0 right-0 z-50 flex justify-between items-center bg-slate-100 dark:bg-slate-900"
>
  <div class="flex flex-col md:flex-row md:w-full md:items-center">
    <a class="text-3xl text-fuchsia-600 dark:text-fuchsia-400 font-righteous" href="/"
      >{SITE_NAME}</a
    >
    <div class="ms-auto mt-2 md:mt-0">
      <a
        class={currentPath == ""
          ? "mr-3 underline underline-offset-2 decoration-fuchsia-600 dark:decoration-fuchsia-400 font-black"
          : "mr-3"}
        href="/">home</a
      >
      <a
        class={currentPath.startsWith("blog")
          ? "mr-3 underline underline-offset-2 decoration-fuchsia-600 dark:decoration-fuchsia-400 font-black"
          : "mr-3"}
        href="/blog">blog</a
      >
      <a
        class={currentPath == "projects"
          ? "mr-3 underline underline-offset-2 decoration-fuchsia-600 dark:decoration-fuchsia-400 font-black"
          : "mr-3"}
        href="/projects">projects</a
      >
      <a
        class={currentPath == "about"
          ? "mr-3 underline underline-offset-2 decoration-fuchsia-600 dark:decoration-fuchsia-400 font-black"
          : "mr-3"}
        href="/about">about</a
      >
    </div>
  </div>
  <ToggleTheme />
</div>
